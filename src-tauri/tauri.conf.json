{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Absolute protagonist",
  "version": "0.1.0",
  "identifier": "com.absolute-protagonist.desktop-pet",
  "build": {
    "frontendDist": "../src",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: http://asset.localhost; media-src 'self' asset: http://asset.localhost; connect-src ipc: http://ipc.localhost",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**/*",
          "$RESOURCE/**",
          "$APPDATA/**",
          "$APPLOCALDATA/**",
          "$HOME/**"
        ]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "Absolute protagonist",
        "width": 320,
        "height": 392,
        "minWidth": 220,
        "minHeight": 260,
        "resizable": false,
        "decorations": false,
        "transparent": true,
        "shadow": false,
        "skipTaskbar": true,
        "alwaysOnTop": true,
        "visible": true,
        "center": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": ["../icon/icon.ico", "../icon/icon.png"],
    "resources": {
      "../assets": "assets",
      "../icon": "icon"
    },
    "windows": {
      "nsis": {
        "installerIcon": "../icon/icon.ico",
        "uninstallerIcon": "../icon/icon.ico",
        "installMode": "currentUser",
        "languages": ["SimpChinese"],
        "displayLanguageSelector": false,
        "compression": "lzma"
      }
    }
  }
}
